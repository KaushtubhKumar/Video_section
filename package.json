{
  "name": "video-module-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @video-module/web",
    "dev:server": "npm run dev -w @video-module/server",
    "build:web": "npm run build -w @video-module/web",
    "build:server": "npm run build -w @video-module/server",
    "ingest": "npm run ingest -w @video-module/server"
  }
}
