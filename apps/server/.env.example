PORT=4000
YOUTUBE_API_KEY=
CRON_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# LLM relevance gate (Gemini tried first, falls back to Groq on failure)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL=openai/gpt-oss-20b

RELEVANCE_GATE_BATCH_DELAY_MS=1500
# Crawler tuning (all optional — sane defaults are baked in)
# Pipe-separated list of search queries, overrides the built-in defaults
YOUTUBE_SEARCH_QUERIES=
# How many days back search.list looks on each run
PUBLISHED_AFTER_DAYS=14
# Pages of 25 results to pull per query (each extra page = 1 more API unit x 100)
YOUTUBE_SEARCH_MAX_PAGES=1
# How many videos are sent to the LLM per classification call
RELEVANCE_GATE_BATCH_SIZE=15
